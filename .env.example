# PostgreSQL Connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=assamwris

# GeoServer Configuration
# For client-side mapping layers, NEXT_PUBLIC_ variables are exposed securely to the browser.
NEXT_PUBLIC_GEOSERVER_URL=http://localhost:8080/geoserver
NEXT_PUBLIC_GEOSERVER_WORKSPACE=assam
NEXT_PUBLIC_GEOSERVER_USER=admin
NEXT_PUBLIC_GEOSERVER_PASSWORD=geoserver

# Optional: Map logical layers on this website to your actual GeoServer typenames/table names
# (Useful if you named your layers differently inside your GeoServer workspace)
GEOSERVER_LAYER_GAUGE_STATIONS=gauge_stations
GEOSERVER_LAYER_CGWB_DATA=cgwb_data
GEOSERVER_LAYER_WATERBODIES_AMRUT=waterbodies_amrut
GEOSERVER_LAYER_DISTRICT_POLYGONS=district_polygons
GEOSERVER_LAYER_STATE_BOUNDARY=state_boundary
GEOSERVER_LAYER_MAJOR_RIVERS=major_rivers
GEOSERVER_LAYER_BASIN_DELINEATION=basin_delineation
GEOSERVER_LAYER_AQUIFER_ZONES=aquifer_zones
GEOSERVER_LAYER_RAINFALL_GRID=rainfall_grid
GEOSERVER_LAYER_CGWB=cgwb
GEOSERVER_LAYER_RIVER_NETWORK=river_network
